{
  "name": "ag-virtual-scroll",
  "version": "1.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-user/ag-virtual-scroll.git"
  },
  "homepage": "https://ericferreira1992.github.io/ag-virtual-scroll",
  "bugs": {
    "url": "https://github.com/your-user/ag-virtual-scroll/issues"
  },
  "scripts": {
    "ng": "ng",
    "deploy-git-pages": "ng build demo -c=production --base-href=/ag-virtual-scroll/ && node node_modules/gh-pages/bin/gh-pages -d ./dist/demo",
    "build-and-publish": "npm run build-lib && npm run publish-pkg",
    "build-lib": "ng build library && node copy && cd dist/library && npm pack",
    "publish-pkg": "pushd dist/library && npm publish"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "21.2.17",
    "@angular/cdk": "20.1.4",
    "@angular/common": "21.2.17",
    "@angular/compiler": "21.2.17",
    "@angular/core": "21.2.17",
    "@angular/forms": "21.2.17",
    "@angular/material": "20.1.4",
    "@angular/platform-browser": "21.2.17",
    "@angular/platform-browser-dynamic": "21.2.17",
    "@angular/router": "21.2.17",
    "@faker-js/faker": "^8.3.1",
    "ngx-highlightjs": "^10.0.0",
    "rxjs": "7.8.1",
    "tslib": "2.4.1",
    "zone.js": "0.15.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.15",
    "@angular/cli": "^21.2.15",
    "@angular/compiler-cli": "21.2.17",
    "@types/jasmine": "~4.3.0",
    "cpx": "^1.5.0",
    "gh-pages": "^6.2.0",
    "jasmine-core": "~4.6.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "ng-packagr": "^21.2.5",
    "typescript": "5.9.3"
  }
}
